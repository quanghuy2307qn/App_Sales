<mvc:View controllerName="app.sales.salesapp.controller.Sales"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:mdc="sap.ui.mdc">
    <Page id="page" title="{i18n>title}">
      <mdc:FilterBar 
        id="idFilterBar"
        liveMode="true"
        p13nMode="Item,Value"
        >

        <mdc:filterItems>
            <mdc:FilterField id="idLabelCustomerFilter" label="Customer" propertyKey="customer" dataType="sap.ui.model.type.String"></mdc:FilterField>
            <mdc:FilterField id="idLabelAmountFilter" label="Customer" propertyKey="totalAmount" dataType="sap.ui.model.type.Decimal"></mdc:FilterField>
            <mdc:FilterField id="idLabelStatusFilter" label="Customer" propertyKey="status" dataType="sap.ui.model.type.String"></mdc:FilterField>

        </mdc:filterItems>
    

      </mdc:FilterBar>
        <content>
            <Table id='salesTable' items="{ path: '/SalesOrders' }" growing="true" growingScrollToLoad="true">
                <columns>
                    <Column id="idCustomer" >
                        <Text id="idTextCustomer" text="Customer"/>
                    </Column>

                    <Column id="idAmount" >
                        <Text id="idTextAmount" text="Amount"/>
                    </Column>

                    <Column id="idStatus" >
                        <Text id="idTextStatus" text="Status"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="idListItem" type="Navigation" press=".onPressDetail">
                        <cells>
                            <Text id="idTextItemCustomer" text="{customer}"></Text>
                            <Text id="idTextItemAmount" text="{totalAmount}"></Text>
                            <Text id="idTextItemStatus" text="{status}"></Text>                           
                        </cells>                   
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>